{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://metagraph.sh/schemas/components/06-health.schema.json",
  "title": "Metagraphed OpenAPI components 06-health",
  "type": "object",
  "components": {
    "schemas": {
      "HealthSurface": {
        "type": "object",
        "required": ["surface_id", "netuid", "status", "classification", "url"],
        "properties": {
          "auth_required": {
            "type": "boolean"
          },
          "surface_id": {
            "type": "string"
          },
          "netuid": {
            "type": "integer",
            "minimum": 0
          },
          "subnet_name": {
            "type": "string"
          },
          "subnet_slug": {
            "type": "string"
          },
          "kind": {
            "$ref": "#/components/schemas/SurfaceKind"
          },
          "provider": {
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/HealthStatus"
          },
          "classification": {
            "$ref": "#/components/schemas/Classification"
          },
          "content_type": {
            "type": ["string", "null"]
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "latency_ms": {
            "type": ["integer", "null"],
            "minimum": 0
          },
          "method_tested": {
            "type": "string"
          },
          "private_redirect_blocked": {
            "type": "boolean"
          },
          "public_safe": {
            "type": "boolean"
          },
          "redirect_target": {
            "type": ["string", "null"],
            "format": "uri"
          },
          "status_code": {
            "type": ["integer", "null"]
          },
          "last_checked": {
            "type": ["string", "null"]
          },
          "last_ok": {
            "type": ["string", "null"]
          },
          "verified_at": {
            "type": ["string", "null"]
          },
          "error": {
            "type": ["string", "null"]
          },
          "error_class": {
            "type": ["string", "null"]
          },
          "uptime_sample_ratio": {
            "type": ["number", "null"],
            "minimum": 0,
            "maximum": 1
          },
          "archive_support": {
            "type": ["boolean", "null"]
          },
          "latest_block": {
            "type": ["integer", "null"],
            "minimum": 0
          },
          "method_results": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "methods_supported": {
            "oneOf": [
              {
                "type": "object",
                "additionalProperties": {
                  "type": "boolean"
                }
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              {
                "type": "null"
              }
            ]
          },
          "rpc_method_count": {
            "type": ["integer", "null"],
            "minimum": 0
          }
        },
        "additionalProperties": false
      },
      "HealthHistorySurface": {
        "type": "object",
        "required": [
          "surface_id",
          "netuid",
          "kind",
          "provider",
          "status",
          "classification"
        ],
        "properties": {
          "surface_id": {
            "type": "string"
          },
          "netuid": {
            "type": "integer",
            "minimum": 0
          },
          "kind": {
            "$ref": "#/components/schemas/SurfaceKind"
          },
          "provider": {
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/HealthStatus"
          },
          "classification": {
            "$ref": "#/components/schemas/Classification"
          },
          "latency_ms": {
            "type": ["integer", "null"],
            "minimum": 0
          },
          "status_code": {
            "type": ["integer", "null"]
          },
          "last_checked": {
            "type": ["string", "null"]
          },
          "last_ok": {
            "type": ["string", "null"]
          },
          "verified_at": {
            "type": ["string", "null"]
          },
          "error_class": {
            "type": ["string", "null"]
          }
        },
        "additionalProperties": false
      },
      "HealthSubnetSummary": {
        "type": "object",
        "required": [
          "status",
          "surface_count",
          "ok_count",
          "failed_count",
          "degraded_count",
          "unknown_count"
        ],
        "properties": {
          "netuid": {
            "type": "integer",
            "minimum": 0
          },
          "slug": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/HealthStatus"
          },
          "surface_count": {
            "type": "integer",
            "minimum": 0
          },
          "ok_count": {
            "type": "integer",
            "minimum": 0
          },
          "failed_count": {
            "type": "integer",
            "minimum": 0
          },
          "degraded_count": {
            "type": "integer",
            "minimum": 0
          },
          "unknown_count": {
            "type": "integer",
            "minimum": 0
          },
          "last_checked": {
            "type": ["string", "null"]
          },
          "last_ok": {
            "type": ["string", "null"]
          },
          "avg_latency_ms": {
            "type": ["integer", "null"],
            "minimum": 0
          }
        },
        "additionalProperties": false
      },
      "HealthLatestArtifact": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ArtifactBase"
          },
          {
            "type": "object",
            "required": ["observed_at", "summary", "surfaces"],
            "properties": {
              "observed_at": {
                "type": ["string", "null"],
                "format": "date-time"
              },
              "summary": {
                "type": "object",
                "additionalProperties": true
              },
              "surfaces": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/HealthSurface"
                }
              }
            },
            "additionalProperties": true
          }
        ]
      },
      "HealthSummaryArtifact": {
        "type": "object",
        "description": "Live-computed global operational health (served from KV/D1; `unknown` when the live store is cold). No longer a static artifact.",
        "required": ["schema_version", "global", "subnets"],
        "properties": {
          "schema_version": { "type": "integer" },
          "contract_version": { "type": "string" },
          "generated_at": { "type": ["string", "null"] },
          "scope": { "type": "string" },
          "source": { "type": "string" },
          "health_source": { "type": "string" },
          "operational_observed_at": { "type": ["string", "null"] },
          "global": {
            "type": "object",
            "additionalProperties": true
          },
          "subnets": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/HealthSubnetSummary"
            }
          }
        },
        "additionalProperties": true
      },
      "HealthHistoryArtifact": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ArtifactBase"
          },
          {
            "type": "object",
            "required": ["date", "summary", "surfaces"],
            "properties": {
              "date": {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
              },
              "source": {
                "type": "string"
              },
              "probe_started_at": {
                "type": ["string", "null"]
              },
              "probe_finished_at": {
                "type": ["string", "null"]
              },
              "summary": {
                "type": "object",
                "description": "Aggregate probe outcome counts for the day.",
                "properties": {
                  "surface_count": { "type": "integer", "minimum": 0 },
                  "status_counts": {
                    "type": "object",
                    "additionalProperties": { "type": "integer", "minimum": 0 }
                  },
                  "classification_counts": {
                    "type": "object",
                    "additionalProperties": { "type": "integer", "minimum": 0 }
                  }
                },
                "additionalProperties": true
              },
              "surfaces": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/HealthHistorySurface"
                }
              }
            },
            "additionalProperties": true
          }
        ]
      },
      "HealthSubnetArtifact": {
        "type": "object",
        "description": "Live-computed per-subnet operational health (served from KV/D1; `unknown` when the live store is cold). Identity fields (slug/name/generated_at) are optional because health is no longer sourced from a static artifact.",
        "required": ["schema_version", "netuid", "summary", "surfaces"],
        "properties": {
          "schema_version": { "type": "integer" },
          "contract_version": { "type": "string" },
          "generated_at": { "type": ["string", "null"] },
          "netuid": {
            "type": "integer",
            "minimum": 0
          },
          "slug": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "health_source": { "type": "string" },
          "operational_observed_at": { "type": ["string", "null"] },
          "summary": {
            "$ref": "#/components/schemas/HealthSubnetSummary"
          },
          "surfaces": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/HealthSurface"
            }
          }
        },
        "additionalProperties": true
      },
      "HealthBadgeArtifact": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ArtifactBase"
          },
          {
            "type": "object",
            "required": [
              "netuid",
              "label",
              "message",
              "status",
              "color",
              "surface_count"
            ],
            "properties": {
              "netuid": {
                "type": "integer",
                "minimum": 0
              },
              "label": {
                "type": "string"
              },
              "message": {
                "type": "string"
              },
              "status": {
                "$ref": "#/components/schemas/HealthStatus"
              },
              "color": {
                "type": "string"
              },
              "surface_count": {
                "type": "integer",
                "minimum": 0
              }
            },
            "additionalProperties": true
          }
        ]
      },
      "HealthTrendsArtifact": {
        "type": "object",
        "required": ["schema_version", "netuid", "source", "windows"],
        "properties": {
          "schema_version": { "type": "integer" },
          "netuid": { "type": "integer", "minimum": 0 },
          "observed_at": { "type": ["string", "null"] },
          "source": { "type": "string" },
          "windows": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "required": ["samples", "uptime_ratio", "surfaces"],
              "properties": {
                "samples": { "type": "integer", "minimum": 0 },
                "uptime_ratio": { "type": ["number", "null"] },
                "surfaces": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": [
                      "surface_id",
                      "samples",
                      "uptime_ratio",
                      "avg_latency_ms"
                    ],
                    "properties": {
                      "surface_id": { "type": "string" },
                      "samples": { "type": "integer", "minimum": 0 },
                      "uptime_ratio": { "type": ["number", "null"] },
                      "avg_latency_ms": { "type": ["integer", "null"] }
                    },
                    "additionalProperties": true
                  }
                }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      },
      "HealthPercentilesArtifact": {
        "type": "object",
        "required": ["schema_version", "netuid", "source", "surfaces"],
        "properties": {
          "schema_version": { "type": "integer" },
          "netuid": { "type": "integer", "minimum": 0 },
          "window": { "type": ["string", "null"] },
          "observed_at": { "type": ["string", "null"] },
          "source": { "type": "string" },
          "surfaces": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["surface_id", "samples", "latency_ms"],
              "properties": {
                "surface_id": { "type": "string" },
                "samples": { "type": "integer", "minimum": 0 },
                "latency_ms": {
                  "type": "object",
                  "properties": {
                    "p50": { "type": ["integer", "null"] },
                    "p95": { "type": ["integer", "null"] },
                    "p99": { "type": ["integer", "null"] },
                    "avg": { "type": ["integer", "null"] },
                    "min": { "type": ["integer", "null"] },
                    "max": { "type": ["integer", "null"] }
                  },
                  "additionalProperties": true
                }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      },
      "HealthIncidentsArtifact": {
        "type": "object",
        "required": ["schema_version", "netuid", "source", "surfaces"],
        "properties": {
          "schema_version": { "type": "integer" },
          "netuid": { "type": "integer", "minimum": 0 },
          "window": { "type": ["string", "null"] },
          "observed_at": { "type": ["string", "null"] },
          "source": { "type": "string" },
          "surfaces": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "surface_id",
                "samples",
                "uptime_ratio",
                "incident_count",
                "downtime_ms",
                "incidents"
              ],
              "properties": {
                "surface_id": { "type": "string" },
                "samples": { "type": "integer", "minimum": 0 },
                "uptime_ratio": { "type": ["number", "null"] },
                "incident_count": { "type": "integer", "minimum": 0 },
                "downtime_ms": { "type": "integer", "minimum": 0 },
                "incidents": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": [
                      "started_at",
                      "ended_at",
                      "duration_ms",
                      "failed_samples"
                    ],
                    "properties": {
                      "started_at": { "type": "integer" },
                      "ended_at": { "type": "integer" },
                      "duration_ms": { "type": "integer", "minimum": 0 },
                      "failed_samples": { "type": "integer", "minimum": 0 }
                    },
                    "additionalProperties": true
                  }
                }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      },
      "SubnetTrajectoryArtifact": {
        "type": "object",
        "required": [
          "schema_version",
          "netuid",
          "point_count",
          "points",
          "deltas"
        ],
        "properties": {
          "schema_version": { "type": "integer" },
          "netuid": { "type": "integer", "minimum": 0 },
          "point_count": { "type": "integer", "minimum": 0 },
          "points": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["date"],
              "properties": {
                "date": { "type": "string" },
                "completeness_score": { "type": ["integer", "null"] },
                "surface_count": { "type": ["integer", "null"] },
                "endpoint_count": { "type": ["integer", "null"] }
              },
              "additionalProperties": true
            }
          },
          "deltas": {
            "type": "object",
            "additionalProperties": {
              "type": ["object", "null"],
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      },
      "GlobalIncidentsArtifact": {
        "type": "object",
        "description": "Recent cross-subnet downtime incidents reconstructed from probe history; lists only surfaces that had an incident in the window.",
        "required": ["schema_version", "source", "summary", "surfaces"],
        "properties": {
          "schema_version": { "type": "integer" },
          "window": { "type": ["string", "null"] },
          "observed_at": { "type": ["string", "null"] },
          "source": { "type": "string" },
          "summary": {
            "type": "object",
            "required": ["incident_count", "affected_surface_count"],
            "properties": {
              "incident_count": { "type": "integer", "minimum": 0 },
              "affected_surface_count": { "type": "integer", "minimum": 0 }
            },
            "additionalProperties": true
          },
          "surfaces": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "netuid",
                "surface_id",
                "incident_count",
                "incidents"
              ],
              "properties": {
                "netuid": { "type": "integer", "minimum": 0 },
                "surface_id": { "type": "string" },
                "incident_count": { "type": "integer", "minimum": 0 },
                "downtime_ms": { "type": "integer", "minimum": 0 },
                "incidents": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["started_at", "ended_at", "duration_ms"],
                    "properties": {
                      "started_at": { "type": "integer" },
                      "ended_at": { "type": "integer" },
                      "duration_ms": { "type": "integer", "minimum": 0 },
                      "failed_samples": { "type": "integer", "minimum": 0 }
                    },
                    "additionalProperties": true
                  }
                }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      },
      "RpcUsageArtifact": {
        "type": "object",
        "description": "RPC reverse-proxy usage analytics over a 7d/30d window: request volume, latency percentiles, failover + error rate, cache-hit rate, and the per-endpoint request distribution. Computed live from the rpc_proxy_events telemetry (no static file).",
        "required": [
          "schema_version",
          "source",
          "summary",
          "endpoints",
          "networks"
        ],
        "properties": {
          "schema_version": { "type": "integer" },
          "window": { "type": ["string", "null"] },
          "observed_at": { "type": ["string", "null"] },
          "source": { "type": "string" },
          "summary": {
            "type": "object",
            "required": ["total_requests", "ok_requests", "error_requests"],
            "properties": {
              "total_requests": { "type": "integer", "minimum": 0 },
              "ok_requests": { "type": "integer", "minimum": 0 },
              "error_requests": { "type": "integer", "minimum": 0 },
              "error_rate": { "type": ["number", "null"] },
              "failover_requests": { "type": "integer", "minimum": 0 },
              "failover_rate": { "type": ["number", "null"] },
              "cache_hits": { "type": "integer", "minimum": 0 },
              "cache_hit_rate": { "type": ["number", "null"] },
              "latency_ms": {
                "type": "object",
                "properties": {
                  "p50": { "type": ["integer", "null"] },
                  "p95": { "type": ["integer", "null"] },
                  "avg": { "type": ["integer", "null"] }
                },
                "additionalProperties": true
              }
            },
            "additionalProperties": true
          },
          "endpoints": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["endpoint_id", "requests", "ok_requests"],
              "properties": {
                "rank": { "type": "integer", "minimum": 1 },
                "endpoint_id": { "type": ["string", "null"] },
                "provider": { "type": ["string", "null"] },
                "requests": { "type": "integer", "minimum": 0 },
                "ok_requests": { "type": "integer", "minimum": 0 },
                "error_rate": { "type": ["number", "null"] },
                "avg_latency_ms": { "type": ["integer", "null"] }
              },
              "additionalProperties": true
            }
          },
          "networks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["network", "requests", "ok_requests"],
              "properties": {
                "network": { "type": "string" },
                "requests": { "type": "integer", "minimum": 0 },
                "ok_requests": { "type": "integer", "minimum": 0 },
                "error_rate": { "type": ["number", "null"] }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      },
      "ReliabilityScore": {
        "type": "object",
        "description": "Composite reliability score (0-100) from durable uptime history: sample-weighted uptime with a mild latency penalty. Null when no probe data exists.",
        "required": ["score", "grade", "uptime_ratio", "sample_count"],
        "properties": {
          "score": { "type": "integer", "minimum": 0, "maximum": 100 },
          "grade": { "type": "string", "enum": ["A", "B", "C", "D", "F"] },
          "uptime_ratio": { "type": ["number", "null"] },
          "avg_latency_ms": { "type": ["integer", "null"] },
          "sample_count": { "type": "integer", "minimum": 0 },
          "window": { "type": ["string", "null"] },
          "surface_count": { "type": "integer", "minimum": 0 },
          "day_count": { "type": "integer", "minimum": 0 },
          "computed_at": { "type": ["string", "null"] }
        },
        "additionalProperties": true
      },
      "UptimeArtifact": {
        "type": "object",
        "required": ["schema_version", "netuid", "source", "surfaces"],
        "properties": {
          "schema_version": { "type": "integer" },
          "netuid": { "type": "integer", "minimum": 0 },
          "window": { "type": ["string", "null"] },
          "source": { "type": "string" },
          "reliability": {
            "oneOf": [
              { "$ref": "#/components/schemas/ReliabilityScore" },
              { "type": "null" }
            ]
          },
          "surfaces": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "surface_id",
                "day_count",
                "samples",
                "uptime_ratio",
                "days"
              ],
              "properties": {
                "surface_id": { "type": "string" },
                "day_count": { "type": "integer", "minimum": 0 },
                "samples": { "type": "integer", "minimum": 0 },
                "uptime_ratio": { "type": ["number", "null"] },
                "reliability": {
                  "oneOf": [
                    { "$ref": "#/components/schemas/ReliabilityScore" },
                    { "type": "null" }
                  ]
                },
                "days": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["day", "samples", "uptime_ratio", "status"],
                    "properties": {
                      "day": { "type": "string" },
                      "samples": { "type": "integer", "minimum": 0 },
                      "uptime_ratio": { "type": ["number", "null"] },
                      "avg_latency_ms": { "type": ["integer", "null"] },
                      "status": { "type": "string" }
                    },
                    "additionalProperties": true
                  }
                }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      },
      "RegistryLeaderboardsArtifact": {
        "type": "object",
        "required": ["schema_version", "source", "boards"],
        "properties": {
          "schema_version": { "type": "integer" },
          "board": { "type": ["string", "null"] },
          "observed_at": { "type": ["string", "null"] },
          "source": { "type": "string" },
          "boards": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": { "type": "object", "additionalProperties": true }
            }
          }
        },
        "additionalProperties": true
      }
    }
  }
}
